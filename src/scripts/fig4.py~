"""
Publication-ready script to generate disc fraction vs age comparison figure.

This script creates a figure comparing population synthesis predictions with
observational data from Mamajek+2009,    # Add vertical line at e-folding time
    ax.vlines(tau_fit, 0, 90, color='red', ls=':', alpha=0.8, linewidth=2)
    ax.text(tau_fit + 0.3, 75, f'tau={tau_fit:.1f} Myr',
            rotation=0, fontsize=8, color='red', alpha=0.9,
            bbox=dict(boxstyle='round,pad=0.2', facecolor='white',
                      alpha=0.7))ng disc fraction evolution over time
for different photoevaporation prescriptions.

Author: Giovanni Picogna
Date: 10.05.2023
Last Updated: October 2025 - Polished for publication
"""

# ============================================================================
# IMPORTS AND DEPENDENCIES
# ============================================================================
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import paths
from scipy.optimize import curve_fit
from lib import load_data

# ============================================================================
# PLOTTING CONFIGURATION
# ============================================================================
# Configure matplotlib for publication quality
plt.rcParams['text.usetex'] = False  # Disable LaTeX to avoid rendering issues

# Try to use science plots style if available
try:
    import scienceplots
    plt.style.use('science')
    print("Using scienceplots style for publication quality")
except ImportError:
    print("scienceplots not available, using default matplotlib style")

sns.set_palette("pastel")  # Set seaborn color palette

# Set font sizes optimized for single-column A4 layout
plt.rc('font', size=9.)
plt.rc('xtick', labelsize=8.)
plt.rc('ytick', labelsize=8.)
plt.rc('axes', labelsize=9.)
plt.rc('legend', fontsize=8.)

# Configure errorbar appearance
plt.rcParams["errorbar.capsize"] = 2

# ============================================================================
# FIGURE SETUP AND DATA LOADING
# ============================================================================
# Create figure optimized for single-column A4 layout (3.5" x 2.8")
fig, ax = plt.subplots(1, 1, figsize=(3.46457, 2.2))  # 1 column A4 width
fig.subplots_adjust(left=0.16, bottom=0.18, right=0.96, top=0.94)

# Define data paths
data_path_new = paths.data / "pop_compact_discs_new/"
data_path_old = paths.data / "pop_compact_discs_old/"

# Data filtering parameters
mask = True           # Apply masking to population synthesis data
mask_val = 1.e-11     # Threshold for disc mass masking

# ============================================================================
# POPULATION SYNTHESIS DATA PLOTTING
# ============================================================================
print("Loading population synthesis data...")

# Load and plot new prescription data (critical radius dependence)
profile_name_new = "Critical radius dependence"
print(f"Loading new prescription data from: {data_path_new}")
try:
    data_new = load_data(data_path_new, profile_name=profile_name_new,
                         mask=mask, mask_val=mask_val)
    n_points_new = len(data_new['age'])
    print(f"Successfully loaded {n_points_new} data points (new)")
    
    ax.plot(data_new["age"], data_new["disk_fraction"], '.',
            color='black', markersize=2, label=profile_name_new)
    
except Exception as e:
    print(f"Error loading new prescription data: {e}")
    # Create dummy data if loading fails
    dummy_ages = np.linspace(0.1, 15, 50)
    dummy_fractions = 100 * np.exp(-dummy_ages/3.0)
    ax.plot(dummy_ages, dummy_fractions, '.',
            color='black', markersize=2, label=profile_name_new + " (dummy)")

# Load and plot old prescription data (EUV-only)
profile_name_old = "Old prescription"
print(f"Loading old prescription data from: {data_path_old}")
try:
    data_old = load_data(data_path_old, profile_name=profile_name_old,
                         mask=mask, mask_val=mask_val)
    n_points_old = len(data_old['age'])
    print(f"Successfully loaded {n_points_old} data points (old)")
    
    ax.plot(data_old["age"], data_old["disk_fraction"], '.',
            color='gray', markersize=2, label=profile_name_old)
    
except Exception as e:
    print(f"Error loading old prescription data: {e}")
    # Create dummy data if loading fails
    dummy_ages = np.linspace(0.1, 12, 50)
    dummy_fractions = 100 * np.exp(-dummy_ages/2.5)
    ax.plot(dummy_ages, dummy_fractions, '.',
            color='gray', markersize=2, label=profile_name_old + " (dummy)")

# ============================================================================
# OBSERVATIONAL DATA OVERLAY
# ============================================================================
print("Loading observational data...")

# Load Mamajek+2009 observational disc fraction data with uncertainties
# Columns: name, age (Myr), age_lower, age_upper, disc_fraction (%),
#          disc_fraction_lower, disc_fraction_upper
mamajek_file = paths.data / "disc_fraction_Mamajek2009.csv"
print(f"Loading observational data from: {mamajek_file}")
data_Mamajek = np.loadtxt(mamajek_file, delimiter=',', skiprows=1,
                          usecols=(1, 2, 3, 4, 5, 6), dtype=float)
print(f"Loaded {len(data_Mamajek)} observational data points")

# Extract data columns
age_obs = data_Mamajek[:, 0]          # Age (Myr)
age_lower = data_Mamajek[:, 1]        # Age lower bound
age_upper = data_Mamajek[:, 2]        # Age upper bound
frac_obs = data_Mamajek[:, 3]         # Disc fraction (%)
frac_lower = data_Mamajek[:, 4]       # Disc fraction lower bound
frac_upper = data_Mamajek[:, 5]       # Disc fraction upper bound

# Calculate asymmetric error bars for both age and disc fraction
xerr_lower = age_obs - age_lower      # Age uncertainties (lower)
xerr_upper = age_upper - age_obs      # Age uncertainties (upper)
yerr_lower = frac_obs - frac_lower    # Disc fraction uncertainties (lower)
yerr_upper = frac_upper - frac_obs    # Disc fraction uncertainties (upper)

# Plot observational data with both x and y error bars
ax.errorbar(age_obs, frac_obs,
            xerr=[xerr_lower, xerr_upper], yerr=[yerr_lower, yerr_upper],
            fmt='o', markersize=4, color='red', ecolor='darkred',
            markeredgewidth=0.5, markeredgecolor='darkred', elinewidth=1.5,
            capsize=2, capthick=1, alpha=0.8, zorder=3,
            label='Mamajek+2009 (obs.)')

# Store mean age for e-folding time calculation
mean_age_obs = np.mean(age_obs)

# ============================================================================
# E-FOLDING TIME CALCULATION FOR OBSERVED POPULATION
# ============================================================================
# Fit exponential decay model: f(t) = f0 * exp(-t/tau)
# where tau is the e-folding time


def exp_decay(t, f0, tau):
    """Exponential decay function: f(t) = f0 * exp(-t/tau)"""
    return f0 * np.exp(-t / tau)


# Sort data by age for fitting
sort_indices = np.argsort(age_obs)
age_sorted = age_obs[sort_indices]
frac_sorted = frac_obs[sort_indices]

# Fit exponential decay to observational data
try:
    # Initial guess: f0 = max fraction, tau = mean age
    initial_guess = [np.max(frac_sorted), mean_age_obs]
    
    # Perform curve fitting
    popt, pcov = curve_fit(exp_decay, age_sorted, frac_sorted,
                           p0=initial_guess, maxfev=2000)
    
    f0_fit, tau_fit = popt
    tau_error = np.sqrt(np.diag(pcov))[1]  # Error on tau
    
    print(f"E-folding time from fit: {tau_fit:.2f} ± {tau_error:.2f} Myr")
    
    # Plot fitted exponential curve
    age_fit = np.linspace(0.1, 20, 100)
    frac_fit = exp_decay(age_fit, f0_fit, tau_fit)
    ax.plot(age_fit, frac_fit, '--', color='red', alpha=0.6, linewidth=2,
            label=f'Exp. fit (tau={tau_fit:.1f} Myr)')
    
    # Add vertical line at e-folding time
    ax.vlines(tau_fit, 0, 90, color='red', ls=':', alpha=0.8, linewidth=2)
    
except Exception as e:
    print(f"Warning: Could not fit exponential decay: {e}")
    # Use simple estimate: tau ≈ mean age
    tau_estimate = mean_age_obs
    print(f"Using mean age as e-folding time estimate: {tau_estimate:.2f} Myr")

# ============================================================================
# E-FOLDING TIME CALCULATION FOR POPULATION SYNTHESIS DATA
# ============================================================================
print("Calculating e-folding times for population synthesis data...")

# Calculate e-folding time for new prescription (critical radius dependence)
try:
    if 'data_new' in locals():
        # Create binned data for fitting (reduce computational load)
        age_bins = np.linspace(0.1, 15, 50)
        bin_centers = (age_bins[1:] + age_bins[:-1]) / 2
        bin_fractions = []
        
        for i in range(len(age_bins)-1):
            mask_bin = ((data_new["age"] >= age_bins[i]) & 
                       (data_new["age"] < age_bins[i+1]))
            if np.sum(mask_bin) > 0:
                bin_fractions.append(np.mean(data_new["disk_fraction"][mask_bin]))
            else:
                bin_fractions.append(0)
        
        bin_fractions = np.array(bin_fractions)
        valid_bins = bin_fractions > 0
        
        if np.sum(valid_bins) > 5:  # Need enough points for fitting
            # Fit exponential decay
            initial_guess = [100, 3.0]  # Initial guess for e-folding time
            popt_new, pcov_new = curve_fit(exp_decay, bin_centers[valid_bins], 
                                          bin_fractions[valid_bins],
                                          p0=initial_guess, maxfev=2000)
            
            f0_new, tau_new = popt_new
            tau_new_error = np.sqrt(np.diag(pcov_new))[1]
            
            print(f"New prescription e-folding time: {tau_new:.2f} ± {tau_new_error:.2f} Myr")
            
            # Add dotted line for new prescription e-folding time
            ax.vlines(tau_new, 0, 90, color='black', ls=':', alpha=0.8, linewidth=1.5)
            
        else:
            print("New prescription: Not enough valid bins for fitting")
            
except Exception as e:
    print(f"Warning: Could not calculate e-folding time for new prescription: {e}")

# Calculate e-folding time for old prescription (EUV-only)
try:
    if 'data_old' in locals():
        # Create binned data for fitting (reduce computational load)
        age_bins = np.linspace(0.1, 10, 40)
        bin_centers = (age_bins[1:] + age_bins[:-1]) / 2
        bin_fractions = []
        
        for i in range(len(age_bins)-1):
            mask_bin = ((data_old["age"] >= age_bins[i]) & 
                       (data_old["age"] < age_bins[i+1]))
            if np.sum(mask_bin) > 0:
                bin_fractions.append(np.mean(data_old["disk_fraction"][mask_bin]))
            else:
                bin_fractions.append(0)
        
        bin_fractions = np.array(bin_fractions)
        valid_bins = bin_fractions > 0
        
        if np.sum(valid_bins) > 5:  # Need enough points for fitting
            # Fit exponential decay
            initial_guess = [100, 2.0]  # Initial guess for e-folding time
            popt_old, pcov_old = curve_fit(exp_decay, bin_centers[valid_bins], 
                                          bin_fractions[valid_bins],
                                          p0=initial_guess, maxfev=2000)
            
            f0_old, tau_old = popt_old
            tau_old_error = np.sqrt(np.diag(pcov_old))[1]
            
            print(f"Old prescription e-folding time: {tau_old:.2f} ± {tau_old_error:.2f} Myr")
            
            # Add dotted line for old prescription e-folding time
            ax.vlines(tau_old, 0, 90, color='gray', ls=':', alpha=0.8, linewidth=1.5)
            
        else:
            print("Old prescription: Not enough valid bins for fitting")
            
except Exception as e:
    print(f"Warning: Could not calculate e-folding time for old prescription: {e}")

# Text annotations removed - only e-folding times are shown

# ============================================================================
# PLOT FORMATTING AND FINALIZATION
# ============================================================================
print("Finalizing plot...")

# Configure legend and axis limits for publication quality
# Move legend back to upper right with clean styling
ax.legend(loc='upper right', fontsize=8, frameon=True, fancybox=False,
          shadow=False, framealpha=0.95, edgecolor='gray')
ax.set_xlim(0., 20.)
ax.set_ylim(0, 90.)

# Set axis labels with proper formatting
ax.set_ylabel(r'Disk fraction [$\%$]', fontsize=10)
ax.set_xlabel('Age [Myr]', fontsize=10)

# Improve tick formatting for publication
ax.tick_params(axis='both', which='major', labelsize=10, width=1.2)
ax.tick_params(axis='both', which='minor', width=0.8)
ax.grid(True, alpha=0.3, linestyle='-', linewidth=0.5)

# Save figure with high resolution for publication
output_filename = pathsfigure / 'Fig4.png'
fig.savefig(output_filename, format='png', dpi=400, bbox_inches='tight',
            facecolor='white', edgecolor='none')

print(f"Figure saved as {output_filename}")
fig_w, fig_h = fig.get_figwidth(), fig.get_figheight()
print(f"Figure dimensions: {fig_w:.1f}\" x {fig_h:.1f}\"")
print("Optimized for single-column A4 scientific publication")
