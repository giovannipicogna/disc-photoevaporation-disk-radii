prefix=/Users/giovanni/Papers/disc-photoevaporation-disk-radii/.snakemake/conda/0e37d6ce77ff237ff2871454a4f1678f_
bindir=${prefix}/bin
mandir=${prefix}/share/man
docdir=${prefix}/share/doc/openjpeg
libdir=${prefix}/lib
includedir=${prefix}/include/openjpeg-2.5

Name: openjp2
Description: JPEG2000 library (Part 1 and 2)
URL: http://www.openjpeg.org/
Version: 2.5.4
Libs: -L${libdir} -lopenjp2
Libs.private: -lm 
Cflags: -I${includedir}
Cflags.private: -DOPJ_STATIC
